@model TradeTrack.AdminPanel.Models.SalesRepDetailsViewModel
@{
    ViewData["Title"] = "Sales Representative Details";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Sales Representative Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Sales Representative Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th>ID:</th>
                                <td>@Model.Id</td>
                            </tr>
                            <tr>
                                <th>Name:</th>
                                <td class="fw-bold">@Model.FullName</td>
                            </tr>
                            <tr>
                                <th>Phone:</th>
                                <td><i class="bi bi-telephone"></i> @Model.Phone</td>
                            </tr>
                            <tr>
                                <th>Email:</th>
                                <td><i class="bi bi-envelope"></i> @Model.Email</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th>Status:</th>
                                <td>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Created:</th>
                                <td>@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                            <tr>
                                <th>Total Orders:</th>
                                <td class="fw-bold">@Model.TotalOrders</td>
                            </tr>
                            <tr>
                                <th>Total Sales:</th>
                                <td class="fw-bold text-success">₹@Model.TotalSales.ToString("N0")</td>
                            </tr>
                            <tr>
                                <th>Active Days:</th>
                                <td>@Model.ActiveDays days</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Performance Stats -->
                <div class="mt-4">
                    <h6>Performance Statistics</h6>
                    <div class="row text-center">
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Avg Daily Sales</h6>
                                    <h4>₹@((Model.ActiveDays > 0 ? Model.TotalSales / Model.ActiveDays : 0).ToString("N0"))</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Avg Order Value</h6>
                                    <h4>₹@((Model.TotalOrders > 0 ? Model.TotalSales / Model.TotalOrders : 0).ToString("N0"))</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Orders/Day</h6>
                                    @* <h4>@((Model.ActiveDays > 0 ? (double)Model.TotalOrders / Model.ActiveDays : 0).ToString("0.0"))</h4> *@
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Success Rate</h6>
                                    @* <h4>@(Model.ActiveDays > 0 ? "100%" : "0%")</h4> *@
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form asp-action="ToggleStatus" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn @(Model.IsActive ? "btn-warning" : "btn-success")"
                                onclick="return confirm('Are you sure?')">
                            <i class="bi @(Model.IsActive ? "bi-person-x" : "bi-person-check")"></i>
                            @(Model.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure? This cannot be undone.')">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>