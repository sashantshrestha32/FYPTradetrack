@model TradeTrack.AdminPanel.Models.SalesRepDetailsViewModel
@{
    ViewData["Title"] = "Sales Representative Details";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Sales Representative Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Sales Representative Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th>ID:</th>
                                <td>@Model.SalesRep.Id</td>
                            </tr>
                            <tr>
                                <th>Name:</th>
                                <td class="fw-bold">@Model.SalesRep.FullName</td>
                            </tr>
                            <tr>
                                <th>Phone:</th>
                                <td><i class="bi bi-telephone"></i> @Model.SalesRep.Phone</td>
                            </tr>
                            <tr>
                                <th>Email:</th>
                                <td><i class="bi bi-envelope"></i> @Model.SalesRep.Email</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-borderless">
                            <tr>
                                <th>Status:</th>
                                <td>
                                    @if (Model.SalesRep.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Created:</th>
                                <td>@Model.SalesRep.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                            <tr>
                                <th>Total Orders:</th>
                                <td class="fw-bold">@Model.SalesRep.TotalOrders</td>
                            </tr>
                            <tr>
                                <th>Total Sales:</th>
                                <td class="fw-bold text-success">₹@Model.SalesRep.TotalSales.ToString("N0")</td>
                            </tr>
                            <tr>
                                <th>Active Days:</th>
                                <td>@Model.SalesRep.ActiveDays days</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Performance Stats -->
                <div class="mt-4">
                    <h6>Performance Statistics</h6>
                    <div class="row text-center">
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Avg Daily Sales</h6>
                                    <h4>₹@((Model.SalesRep.ActiveDays > 0 ? Model.SalesRep.TotalSales / Model.SalesRep.ActiveDays : 0).ToString("N0"))</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Avg Order Value</h6>
                                    <h4>₹@((Model.SalesRep.TotalOrders > 0 ? Model.SalesRep.TotalSales / Model.SalesRep.TotalOrders : 0).ToString("N0"))</h4>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Orders/Day</h6>
                                    @* <h4>@((Model.ActiveDays > 0 ? (double)Model.TotalOrders / Model.ActiveDays : 0).ToString("0.0"))</h4> *@
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6 class="text-muted">Success Rate</h6>
                                    @* <h4>@(Model.ActiveDays > 0 ? "100%" : "0%")</h4> *@
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.SalesRep.Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <form asp-action="ToggleStatus" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.SalesRep.Id" />
                        <button type="submit" class="btn @(Model.SalesRep.IsActive ? "btn-warning" : "btn-success")"
                                onclick="return confirm('Are you sure?')">
                            <i class="bi @(Model.SalesRep.IsActive ? "bi-person-x" : "bi-person-check")"></i>
                            @(Model.SalesRep.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.SalesRep.Id" />
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure? This cannot be undone.')">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Orders Section -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Orders Taken</h5>
            </div>
            <div class="card-body">
                @if (Model.Orders?.Any() == true)
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.Orders)
                                {
                                    <tr>
                                        <td><strong>#@order.Id</strong></td>
                                        <td>@order.CustomerName</td>
                                        <td>₹@order.TotalAmount.ToString("N0")</td>
                                        <td>
                                            @{
                                                var statusColor = order.Status?.ToLower() switch
                                                {
                                                    "completed" => "success",
                                                    "pending" => "warning",
                                                    "cancelled" => "danger",
                                                    _ => "secondary"
                                                };
                                            }
                                            <span class="badge bg-@statusColor">@order.Status</span>
                                        </td>
                                        <td>@order.CreatedAt.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-info" title="View Order">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> No orders taken by this sales representative.
                    </div>
                }
            </div>
        </div>
    </div>
</div>